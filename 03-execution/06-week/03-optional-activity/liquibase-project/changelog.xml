<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
  http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Crear tabla -->
    <changeSet id="1" author="maria">
        <createTable tableName="usuario">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="nombre" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <!-- Insertar datos -->
    <changeSet id="2" author="maria">
        <insert tableName="usuario">
            <column name="nombre" value="Maria"/>
        </insert>
    </changeSet>

    <!-- Agregar columna -->
    <changeSet id="3" author="maria">
        <addColumn tableName="usuario">
            <column name="email" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>

     <!-- Crear relaciones foreign key-->

<changeSet id="4" author="maria">
    <createTable tableName="producto">
        <column name="id" type="SERIAL">
            <constraints primaryKey="true"/>
        </column>
        <column name="usuario_id" type="INT">
            <constraints nullable="false"/>
        </column>
        <column name="nombre" type="VARCHAR(100)"/>
    </createTable>

    <addForeignKeyConstraint baseTableName="producto"
                             baseColumnNames="usuario_id"
                             referencedTableName="usuario"
                             referencedColumnNames="id"
                             constraintName="fk_producto_usuario"/>
</changeSet>

    </databaseChangeLog>

